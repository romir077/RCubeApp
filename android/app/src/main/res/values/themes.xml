<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base app theme: no action bar; Compose drives the UI. -->
    <style name="Theme.RCube" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/rc_bg</item>
    </style>

    <!-- Splash screen theme (androidx.core:core-splashscreen). -->
    <style name="Theme.RCube.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/rc_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.RCube</item>
    </style>

</resources>
